{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "WriteTo": {
      "File": {
        "Path": "/var/log/maemo/api-.log",
        "RollingInterval": "Day"
      }
    }
  },
  "Deployment": {
    "Mode": "GovOnPrem",
    "EngineMode": {
      "Enabled": true
    }
  },
  "Storage": {
    "LocalBasePath": "/var/maemo/files"
  },
  "Features": {
    "BillingEnabled": false,
    "SelfServiceSignupEnabled": false
  },
  "Security": {
    "EncryptionKey": "CHANGE_THIS_TO_A_32_BYTE_BASE64_KEY_IN_PRODUCTION"
  },
  "HealthChecks": {
    "ApiKey": "",
    "AllowedIPs": ""
  },
  "ConnectionStrings": {
    "MaemoDatabase": "Host=localhost;Port=5432;Database=maemo_gov;Username=maemo_user;Password=maemo_password"
  },
  "Authentication": {
    "Authority": "https://login.microsoftonline.com/{tenantId}/v2.0",
    "Audience": "api://maemo-api-client-id"
  }
}

