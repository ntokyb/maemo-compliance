{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Deployment": {
    "Mode": "SaaS",
    "AdminMode": {
      "Enabled": true
    }
  },
  "Storage": {
    "LocalBasePath": "C:\\MaemoFiles"
  },
  "ConnectionStrings": {
    "MaemoDatabase": "Host=localhost;Port=5432;Database=maemo_dev;Username=maemo_user;Password=maemo_password"
  },
  "Authentication": {
    "Authority": "https://login.microsoftonline.com/{tenantId}/v2.0",
    "Audience": "api://maemo-api-client-id"
  }
}
