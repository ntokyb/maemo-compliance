# Server deployment at /opt/maemo-compliance/app — copy to `.env` on the host.
# Aligns with `docker-compose.prod.yml` and systemd/nginx on the VM.

ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__MaemoDatabase=Host=postgres;Port=5432;Database=maemo_compliance;Username=maemo_compliance;Password=YOUR_STRONG_PASSWORD
POSTGRES_DB=maemo_compliance
POSTGRES_USER=maemo_compliance
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
AZURE_AUTHORITY=https://login.microsoftonline.com/{your-tenant-id}
AZURE_AUDIENCE=api://{your-api-app-client-id}
AZURE_CLIENT_ID={your-spa-app-client-id}
Resend__ApiKey=re_xxxxxxxxxxxx
Resend__FromAddress=admin@maemo-compliance.co.za
App__PublicPortalUrl=https://maemo-compliance.co.za
Features__SelfServiceSignupEnabled=true
Features__BillingEnabled=false
Storage__ForceLocalFileStorage=true
Storage__LocalBasePath=/app/files
Admin__DemoSeedApiKey=
