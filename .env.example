# Copy this file to .env and fill in your values
# Never commit .env to git — it is in .gitignore
# For local dev, only the AZURE_ values are required (and Admin:DemoSeedApiKey for scripted seed)

# Azure AD / Entra ID — required for login
# Create an App Registration in Azure portal
AZURE_AUTHORITY=https://login.microsoftonline.com/{your-tenant-id}/v2.0
AZURE_AUDIENCE=api://{your-api-client-id}

# Optional — SPA client ID (documents MSAL); API JWT validation uses Authority + Audience above
AZURE_CLIENT_ID=

# Demo seed (Development only) — optional; use header X-Maemo-Demo-Seed-Key on POST /admin/v1/seed-demo
# Must match appsettings / env: Admin__DemoSeedApiKey
ADMIN__DEMO_SEED_API_KEY=change-me-demo-seed-key

# Optional — only needed for SaaS SharePoint file storage
# Leave blank / use Storage__ForceLocalFileStorage in compose for local disk (default for dev)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
